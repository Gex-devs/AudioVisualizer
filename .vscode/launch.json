{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "cortex-debug",
      "request": "launch",
      "name": "remote debug",
      "servertype": "external",
      // "gdbTarget": "localhost:3333",
      "gdbTarget": "mini.pc:3333",
      "armToolchainPath": "/usr/bin",
      "gdbPath": "/usr/bin/arm-none-eabi-gdb",
      "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/dot_matrix.elf",
      "device": "STM32F401CC",  
      "runToEntryPoint": "main",
      "svdFile": "${workspaceFolder}/stm32f401.svd",
      "showDevDebugOutput": "vscode",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f4x.cfg"
      ],
      "osx": {
        "gdbPath": "/opt/homebrew/bin/arm-none-eabi-gdb"
      },
      // "preLaunchTask": "start-openocd",
      "liveWatch": {
        "enabled": false,
        "samplesPerSecond": 4
      }
    },
  ]
}
